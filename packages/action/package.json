{
  "name": "@trustboundary/action",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@trustboundary/core": "workspace:*"
  },
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "pnpm --filter @trustboundary/core build && pnpm run build && node --test test/**/*.test.mjs"
  }
}
