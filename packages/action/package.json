{
  "name": "@trustboundary/action",
  "description": "GitHub Action wrapper for TrustBoundary confirmed-critical gating.",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@trustboundary/core": "workspace:*",
    "@trustboundary/report": "workspace:*"
  },
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "dist-bundle"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/bundle.mjs",
    "bundle": "node ./scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "pnpm --filter @trustboundary/core build && pnpm --filter @trustboundary/report build && pnpm run build && node --test test/**/*.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
